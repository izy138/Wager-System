NODE_ENV=development

API_PORT=8080
DB_PORT=5432

# Auth
# NOTE: Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=15m
BCRYPT_ROUNDS=12

# Used when running the API locally (npm run dev).
# Comment this out when running via docker:api, docker-compose overrides it.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ante_db
